{
  "name": "koi-web",
  "private": true,
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "rpc-bindings": "cargo run --manifest-path ../../Cargo.toml -p koi-api --bin rpc-bindings && ts-to-zod src/api/bindings.gen.ts src/api/bindings.zod.gen.ts --skipValidation && node scripts/normalize-rpc-zod.mjs",
    "rpc-bindings-check": "pnpm rpc-bindings && git diff --exit-code -- src/api/rpc-contract.gen.ts src/api/bindings.zod.gen.ts",
    "rpc-typecheck": "tsc -p tsconfig.rpc.json",
    "lint": "eslint ."
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^25.6.0",
    "eslint-plugin-v3xlabs": "^1.7.14",
    "solid-devtools": "^0.34.3",
    "tailwindcss": "^4.1.13",
    "ts-to-zod": "5.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.4",
    "vite-plugin-solid": "^2.11.8"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@openlv/session": "0.0.1-beta.11",
    "@openlv/transport": "0.0.1-beta.8",
    "@solid-primitives/storage": "^4.3.4",
    "@tanstack/router-plugin": "^1.167.22",
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-hotkeys": "^0.9.1",
    "@tanstack/solid-query": "^5.99.0",
    "@tanstack/solid-router": "^1.168.20",
    "@tanstack/solid-table": "^8.21.3",
    "blo": "^2.0.0",
    "date-fns": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-v3xlabs": "^1.7.14",
    "qr": "^0.5.5",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.9",
    "ts-pattern": "^5.9.0",
    "viem": "^2.52.2",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@11.5.1"
}
